{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./**/*.ts" // Adjust path if .ts files are in a different folder
  ],
  "exclude": [
    "node_modules",
    "test", // Exclude the test folder,
    "DataTypes"
  ]
}